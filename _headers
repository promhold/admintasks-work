/*
  Security headers for admintasks.work
  Upload to GitHub repository root.
  Activate via Cloudflare: Rules → Transform Rules → Modify Response Headers → Static.

  X-Frame-Options: SAMEORIGIN

  X-Content-Type-Options: nosniff

  Referrer-Policy: strict-origin-when-cross-origin

  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https://ko-fi.com; connect-src 'self' https://api.spreeapp.com https://ko-fi.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.spreeapp.com; frame-ancestors 'self'; upgrade-insecure-requests;

  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=(), interest-cohort=()

  Cross-Origin-Opener-Policy: same-origin

  Cross-Origin-Resource-Policy: same-origin

  X-DNS-Prefetch-Control: off

  # Uncomment ONLY after HTTPS is confirmed working:
  # Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
