/*
  Security headers for admintasks.work
  Upload this file to your GitHub repository root alongside index.html.

  GitHub Pages does NOT read this file natively.
  To activate these headers, either:
    A) Use Cloudflare Pages (free) — it reads _headers automatically
    B) Use Netlify (free) — it reads _headers automatically
    C) GitHub Pages + Cloudflare proxy — add these manually under:
       Cloudflare dashboard → Rules → Transform Rules → Modify Response Headers

  All values below match the meta-tag CSP already in index.html,
  but HTTP headers take effect BEFORE the page loads — stronger protection.

  X-Frame-Options: SAMEORIGIN

  X-Content-Type-Options: nosniff

  Referrer-Policy: strict-origin-when-cross-origin

  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.spreeapp.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.spreeapp.com; frame-ancestors 'self'; upgrade-insecure-requests;

  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=(), interest-cohort=()

  Cross-Origin-Opener-Policy: same-origin

  Cross-Origin-Resource-Policy: same-origin

  X-DNS-Prefetch-Control: off

  # Uncomment the line below ONLY after confirming HTTPS works on your domain.
  # HSTS tells browsers to never use HTTP again for 1 year — cannot be undone easily.
  # Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
